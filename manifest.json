{
  "manifest_version": 3,
  "name": "CHESS-HACKS",
  "version": "1.0",
  "description": "SHIVANSH AI CHESS BOT",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "permissions": [
    "activeTab",
    "debugger",
    "windows",
    "offscreen",
    "tabs",
    "webNavigation",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://chess.com/*",
    "https://*.chess.com/*",
    "https://api.timezonedb.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*",
    "https://lichess.org/*",
    "https://worldchess.com/*",
    "https://fonts.googleapis.com/*",
    "https://text-and-audio.chess.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "alert.js",
        "lib/chess_min.js",
        "utils/const.js",
        "utils/config.js",
        "utils/engines.js",
        "utils/func.js",
        "utils/draw.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "a.js",
        "b.js",
        "lib/chess_min.js",
        "lib/komodo.js",
        "lib/komodo.wasm",
        "lib/stockfish.wasm",
        "lib/stockfish.js",
        "lib/torch.js",
        "lib/torch.wasm",
        "dist/index.html",
        "book/book.bin",
        "book/*",
        "audio.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}